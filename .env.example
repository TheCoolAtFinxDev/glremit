# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# ── Database (Supabase) ───────────────────────────────────────
DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@[YOUR_POOLER_HOST]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@[YOUR_POOLER_HOST]:5432/postgres"

# ── DB Host ───────────────────────────────────────────────────────
DB_HOST=[YOUR_POOLER_HOST]
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.[YOUR_PROJECT_REF]
DB_PASSWORD=[YOUR_PASSWORD]

# ── Supabase Configuration ────────────────────────────────────
SUPABASE_URL="https://[YOUR_PROJECT_REF].supabase.co"
SUPABASE_ANON_KEY="your_supabase_anon_key"

# ── WSO2 Identity Server Configuration ────────────────────────
WSO2_CLIENT_ID="your_wso2_client_id"
WSO2_CLIENT_SECRET="your_wso2_client_secret"
WSO2_ISSUER_URL="https://localhost:9443/oauth2/token"

# ── Novu Configuration ────────────────────────────────────────
NOVU_API_KEY="your_novu_api_key"

# ── Ballerine Configuration ────────────────────────────────────
BALLERINE_API_KEY="your_ballerine_api_key"

# ── Directus CMS Configuration ────────────────────────────────
DIRECTUS_API_KEY="your_directus_api_key"
DIRECTUS_URL="https://localhost:8055"
